{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Launch FastAPI",
            "type": "debugpy",
            "request": "launch",
            "module": "uvicorn",
            "args": ["app.main:app", "--reload"],
            "cwd": "${workspaceFolder}/backend"
        },
        {
            "name": "Test Api All",
            "type": "debugpy",
            "request": "launch",
            "module": "pytest",
            "args": ["-s", "-v", "tests/api/"],
            "cwd": "${workspaceFolder}/backend"
        },
         {
            "name": "Test Crud",
            "type": "debugpy",
            "request": "launch",
            "module": "pytest",
            "args": ["-s", "-v", "tests/crud/"],
            "cwd": "${workspaceFolder}/backend"
        },
        {
            "name": "Test Users",
            "type": "debugpy",
            "request": "launch",
            "module": "pytest",
            "args": ["-s", "-v", "tests/api/routes/test_users.py"],
            "cwd": "${workspaceFolder}/backend"
        },

           {
            "name": "Test Services",
            "type": "debugpy",
            "request": "launch",
            "module": "pytest",
            "args": ["-s", "-v", "tests/services/"],
            "cwd": "${workspaceFolder}/backend"
        },

    ]
}
